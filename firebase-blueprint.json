{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "streak": { "type": "number" },
        "lastStudyDate": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "task": {
      "title": "Task",
      "description": "A study task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "deadline": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "completed"]
    },
    "course": {
      "title": "Course",
      "description": "A course with topics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "topics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["id", "uid", "name"]
    },
    "exam": {
      "title": "Exam",
      "description": "An exam schedule",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["id", "uid", "subject", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profile documents"
    },
    "/tasks/{taskId}": {
      "schema": "task",
      "description": "User tasks"
    },
    "/courses/{courseId}": {
      "schema": "course",
      "description": "User courses"
    },
    "/exams/{examId}": {
      "schema": "exam",
      "description": "User exams"
    }
  }
}
